# App
APP_NAME="Serviq Local Agent"
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8787
APP_CORS_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:5173,http://127.0.0.1:5173

# Security
# Change these before production/local release.
LOCAL_API_TOKEN=change-this-local-token
ENCRYPTION_KEY=change-this-32-byte-secret-key

# LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_DEFAULT_CHAT_MODEL=local-model
LM_STUDIO_DEFAULT_EMBEDDING_MODEL=local-embedding-model

# Databases
SQLITE_DATABASE_URL=sqlite+aiosqlite:///./workspace/serviq.sqlite3
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=serviq_memory

# Workspace
WORKSPACE_DIR=./workspace
UPLOADS_DIR=./workspace/uploads
GENERATED_DIR=./workspace/generated

# Runtime limits
MAX_PARALLEL_AGENT_RUNS=1
DEFAULT_MODEL_CONTEXT_TOKENS=4096
TOOL_TIMEOUT_SECONDS=60
REQUIRE_APPROVAL_FOR_MEDIUM_RISK=true
REQUIRE_APPROVAL_FOR_HIGH_RISK=true
